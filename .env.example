# ── Database ──────────────────────────────────────────────────────────────────
# Production (cPanel — jalankan dari server, gunakan localhost):
DATABASE_URL=postgresql+asyncpg://ukirbinc_broilabs1:PASSWORD@localhost/ukirbinc_broilabs
# Development (lokal):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/smartfarm

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=ganti-dengan-random-string-panjang-minimal-64-karakter
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Broilabs API
DEBUG=false
API_V1_PREFIX=/api/v1
# Sub-path jika API jalan di broilabs.ukirbin.com/api (cPanel Python App)
ROOT_PATH=/backend

# ── CORS (pisah koma, tanpa spasi) ────────────────────────────────────────────
CORS_ORIGINS=https://broilabs.ukirbin.com

# ── IoT Device Authentication ─────────────────────────────────────────────────
IOT_API_KEY=ganti-dengan-secret-key-iot

# ── Fonnte WhatsApp Gateway ───────────────────────────────────────────────────
FONNTE_TOKEN=token-dari-dashboard-fonnte
